[Unit]
Description=lerobot-web-viz FastAPI backend
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/lerobot-web-viz/backend
Environment=LEROBOT_DATASET_PATH=/data/lerobot/my_dataset
Environment=LEROBOT_PRELOAD_FRAMES=12
Environment=LEROBOT_FRAME_CACHE_SIZE=512
ExecStart=/opt/lerobot-web-viz/backend/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3
User=lerobot
Group=lerobot

[Install]
WantedBy=multi-user.target
